{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing scoped to backend policy + services.",
  "packageManager": "npm",
  "reporters": ["clear-text", "progress"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "backend/src/policy/**/*.ts",
    "backend/src/services/**/*.ts",
    "!backend/src/**/*.test.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  },
  "tempDirName": ".stryker-tmp",
  "timeoutMS": 30000,
  "concurrency": 2,
  "disableTypeChecks": "{backend}/src/**/*.ts",
  "logLevel": "info",
  "fileLogLevel": "off"
}
