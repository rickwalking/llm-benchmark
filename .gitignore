# Python
__pycache__/
*.pyc
*.pyo
.venv/
.python-version
*.egg-info/

# Node — both root and per-candidate
node_modules/
**/node_modules/
.npm/
.npm-docker/

# Build / dist artifacts inside candidates
**/dist/
**/build/

# Stryker mutation testing sandboxes (regenerated on each run)
**/.stryker-tmp/
.stryker-tmp/

# Runtime SQLite databases (regenerated by candidate seeds)
**/*.db
**/*.db-shm
**/*.db-wal

# Playwright artifacts
**/test-results/
**/playwright-report/
**/.playwright-mcp/
.playwright-mcp/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs (kept for the model generation summary, but the heavy ones go)
**/dev-server.log
**/build.log
**/install.log

# Harness scratch dirs
**/_workdir/
**/_docker_failed.flag

# Optional: exclude full session/stderr logs from candidates' generation runs.
# These are 5–18 MB each and capture every tool call. Keep `manifest.txt` and
# `stdout.log` (the BENCHMARK COMPLETE marker lives there). Comment out to
# include the full transcripts.
**/_generation/stderr.log
